<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cc.product.mapper.ProductImageMapper">

    <resultMap id="ProductImageResultMap" type="com.cc.product.model.ProductImage">
        <id column="id" property="id"/>
        <result column="product_id" property="productId"/>
        <result column="image_url" property="imageUrl"/>
        <result column="is_primary" property="isPrimary"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <select id="findById" resultMap="ProductImageResultMap">
        SELECT * FROM product_images WHERE id = #{id}
    </select>

    <select id="findByProductId" resultMap="ProductImageResultMap">
        SELECT * FROM product_images WHERE product_id = #{productId} ORDER BY is_primary DESC, sort_order ASC
    </select>

    <select id="findPrimaryByProductId" resultMap="ProductImageResultMap">
        SELECT * FROM product_images WHERE product_id = #{productId} AND is_primary = 1 LIMIT 1
    </select>

    <insert id="insert" parameterType="com.cc.product.model.ProductImage" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO product_images (product_id, image_url, is_primary, sort_order)
        VALUES (#{productId}, #{imageUrl}, #{isPrimary}, #{sortOrder})
    </insert>

    <update id="update" parameterType="com.cc.product.model.ProductImage">
        UPDATE product_images
        <set>
            <if test="imageUrl != null">image_url = #{imageUrl},</if>
            <if test="isPrimary != null">is_primary = #{isPrimary},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM product_images WHERE id = #{id}
    </delete>

    <delete id="deleteByProductId">
        DELETE FROM product_images WHERE product_id = #{productId}
    </delete>

    <update id="clearPrimary">
        UPDATE product_images SET is_primary = 0 WHERE product_id = #{productId}
    </update>

</mapper>