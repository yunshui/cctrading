<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cc.order.mapper.PaymentMapper">

    <resultMap id="PaymentResultMap" type="com.cc.order.model.Payment">
        <id column="id" property="id"/>
        <result column="order_id" property="orderId"/>
        <result column="order_no" property="orderNo"/>
        <result column="payment_no" property="paymentNo"/>
        <result column="amount" property="amount"/>
        <result column="payment_method" property="paymentMethod"/>
        <result column="status" property="status"/>
        <result column="transaction_id" property="transactionId"/>
        <result column="remark" property="remark"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="findById" resultMap="PaymentResultMap">
        SELECT * FROM payments WHERE id = #{id}
    </select>

    <select id="findByPaymentNo" resultMap="PaymentResultMap">
        SELECT * FROM payments WHERE payment_no = #{paymentNo}
    </select>

    <select id="findByOrderNo" resultMap="PaymentResultMap">
        SELECT * FROM payments WHERE order_no = #{orderNo}
    </select>

    <insert id="insert" parameterType="com.cc.order.model.Payment" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO payments (order_id, order_no, payment_no, amount, payment_method, status, transaction_id, remark)
        VALUES (#{orderId}, #{orderNo}, #{paymentNo}, #{amount}, #{paymentMethod}, #{status}, #{transactionId}, #{remark})
    </insert>

    <update id="update" parameterType="com.cc.order.model.Payment">
        UPDATE payments
        <set>
            <if test="status != null">status = #{status},</if>
            <if test="transactionId != null">transaction_id = #{transactionId},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        WHERE id = #{id}
    </update>

    <update id="updateStatus">
        UPDATE payments SET status = #{status} WHERE id = #{id}
    </update>

    <update id="updateTransactionId">
        UPDATE payments SET transaction_id = #{transactionId} WHERE id = #{id}
    </update>

</mapper>